generator client {
  provider      = "prisma-client-js"
  // "native" for local/CI (glibc); musl target for the alpine runtime image so
  // the Prisma query engine binary is present in the deployed container.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      Role     @default(USER)
  password  String
  createdAt DateTime @default(now())
}

model Recipe {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @default("")
  emoji       String   @default("🍲")
  createdAt   DateTime @default(now())

  @@map("recipes")
}
